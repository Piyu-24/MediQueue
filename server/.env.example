# MediQueue — Server environment variables
# Copy this file to .env and fill in your own values. Never commit the real .env.

# App
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database — MongoDB (Atlas connection string, or a local mongodb:// URI)
MONGODB_URI=

# Auth — use long random strings for the secrets
JWT_SECRET=
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=30d

# File uploads — Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email — Gmail needs an App Password, not your normal login
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
