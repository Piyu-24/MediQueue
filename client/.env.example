# =============================================================================
# MediQueue — Client (React) Environment Variables (TEMPLATE)
# =============================================================================
# 1. Copy this file to `.env`  ->  `cp .env.example .env`
# 2. Fill in the values for your environment.
# 3. NEVER commit the real `.env` — it is gitignored.
#
# NOTES (Create React App):
#   * Only variables prefixed with REACT_APP_ are exposed to the app.
#   * Values are baked in at BUILD time, not runtime — rebuild after changing
#     them, and on a host (Vercel/Netlify) set them in the build environment.
#   * Never put secrets here: anything in the client bundle is public.
# =============================================================================

# Base URL of the backend API (must include the /api suffix)
REACT_APP_API_URL=http://localhost:5000/api

# Base URL of the backend Socket.io server (no /api suffix)
REACT_APP_SOCKET_URL=http://localhost:5000
